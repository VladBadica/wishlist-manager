{
  "manifest_version": 3,
  "name": "Wishlist Manager",
  "version": "1.1.0",
  "description": "Save current tab URL",
  "permissions": [
    "storage",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "assets/wishlist-icon.png"
  },
  "icons": {
    "128": "assets/wishlist-icon.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}